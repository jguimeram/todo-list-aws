pipeline {
    agent any
    options { skipDefaultCheckout() }
    stages {
        stage('Get Code') {
            agent { label 'built-in' }
            steps {
                echo '---- CLEAN BEFORE BUILD STARTS ----'
                cleanWs()
                echo '---- DOWNLOAD REPO ----'
                checkout scmGit(
                branches: [[name: '*/master']],
                userRemoteConfigs: [[url: 'https://github.com/jguimeram/todo-list-aws']])
                echo '---- WORKSPACE ----'
                echo WORKSPACE
                echo '---- WHO AM I? ----'
                sh'''
                whoami
                hostname
                '''

                stash name: 'code', includes:'**' //includes everything
            }
        }

        stage('Set Environment') {
            agent { label 'python' }
            steps {
                unstash name: 'code'
                sh'''
                python3 -m venv .venv
                . .venv/bin/activate
                PYTHONPATH=$PWD
                pip install requests pytest
                whoami
                hostname
                '''
            }
        }

        stage('Deploy') {
            agent { label 'built-in' }
            steps {
                unstash name: 'code'
                sh '''
                sam build
                sam deploy --config-env production \
                --stack-name production-todo-list-aws \
                --region us-east-1 \
                --resolve-s3 \
                --capabilities CAPABILITY_IAM \
                --no-disable-rollback \
                --parameter-overrides Stage="production" \
                --save-params \
                --no-confirm-changeset \
                --no-fail-on-empty-changeset
                whoami
                hostname
                '''
                script {
                    env.BASE_URL = sh(returnStdout: true, script: "aws cloudformation describe-stacks --stack-name production-todo-list-aws --query 'Stacks[0].Outputs[?OutputKey==`BaseUrlApi`].OutputValue' --region us-east-1 --output text").trim()

                    writeFile file: 'rest_api.txt', text: env.BASE_URL
                }

                stash name: 'base_url', includes: 'rest_api.txt'
            }
        }

        stage('Rest Test') {
            agent { label 'agent-02' }
            steps {
                unstash name: 'code'
                unstash name: 'base_url'
                script {
                    env.BASE_URL = readFile('rest_api.txt').trim()
                }
                sh '''
                    python3 -m venv .venv
                    . .venv/bin/activate
                    echo "Targeting URL: $BASE_URL"
                    pytest -k "test_api_listtodos or test_api_gettodo" test/integration/todoApiTest.py
                    whoami
                    hostname
                '''
            }
        }

        stage('Promote') {
            agent { label 'built-in' }
            steps {
                unstash name: 'code'
                withCredentials([string(credentialsId: 'c88df4f8-f1d2-4b25-bbe2-da9d8ac9a94e', variable: 'GITHUB')]) {
                    sh"""
                    echo "1. Update remote URL"
                    git config user.email "jenkins@yourdomain.com"
                    git config user.name "Jenkins CI"
                    git remote set-url origin https://jenkins:$GITHUB@github.com/jguimeram/todo-list-aws.git

                    echo "2 - Add samconfig"
                    git checkout master
                    git pull origin master
                    git add -A

                    echo "3 - Push samconfig"
                    git push origin master

                    echo "Who am I?"
                    whoami
                    hostname
                    """
                }
            }
        }
    }

    post {
        always {
            cleanWs()
        }
    }
}
