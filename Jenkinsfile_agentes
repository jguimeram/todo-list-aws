pipeline {
    agent any
    options { skipDefaultCheckout() }
    stages {
        stage('Get Code') {
            agent { label 'built-in' }
            steps {
                echo '---- CLEAN BEFORE BUILD STARTS ----'
                cleanWs()
                echo '---- DOWNLOAD REPO ----'
                checkout scmGit(
                    branches: [[name: '*/develop']],
                    userRemoteConfigs: [[url: 'https://github.com/jguimeram/todo-list-aws']])
                echo '---- DOWNLOAD SAMCONFIG ----'
                sh'''
                curl -L https://raw.githubusercontent.com/jguimeram/todo-list-aws-config/refs/heads/staging/samconfig.toml -o samconfig.toml
                '''
                sh '''
                echo "---- WHO AM I? ----"
                whoami
                echo "---- HOSTNAME ----"
                hostname
                '''
                stash name: 'code', includes:'**'
            }
        }

        stage('Set Environment') {
            agent { label 'python' }
            steps {
                unstash name: 'code'
                sh '''
                python3 -m venv .venv
                . .venv/bin/activate
                pip install requests pytest flake8 bandit
                echo "---- WHO AM I? ----"
                whoami
                echo "---- HOSTNAME ----"
                hostname
                '''
            }
        }

        stage('Static Tests') {
            parallel {
                stage('Flake8') {
                    agent { label 'agent-01' }
                    steps {
                        unstash name: 'code'
                        catchError(buildResult: 'FAILURE', stageResult: 'FAILURE') {
                            sh '''
                                python3 -m venv .venv
                                . .venv/bin/activate
                                flake8 --exit-zero --format=pylint src > flake8.out
                                echo "---- WHO AM I? ----"
                                whoami
                                echo "---- HOSTNAME ----"
                                hostname
                            '''
                        }
                        recordIssues qualityGates: [], tools: [flake8(pattern: 'flake8.out')]
                    }
                }
                stage('Security') {
                    agent { label 'agent-01' }
                    steps {
                        unstash name: 'code'
                        catchError(buildResult: 'FAILURE', stageResult: 'FAILURE') {
                            sh '''
                            python3 -m venv .venv
                            . .venv/bin/activate
                            bandit --exit-zero -r src -f custom -o bandit.out --msg-template "{abspath}:{line}: [{test_id}] {msg}"
                            echo "---- WHO AM I? ----"
                            whoami
                            echo "---- HOSTNAME ----"
                            hostname
                            '''
                        }
                        recordIssues qualityGates: [], tools: [pyLint(pattern: 'bandit.out')]
                    }
                }
            }
        }

        stage('Deploy') {
            agent { label 'built-in' }
            steps {
                unstash name: 'code'
                sh '''
                sam build
                sam deploy --config-env staging
                echo "---- WHO AM I? ----"
                whoami
                echo "---- HOSTNAME ----"
                hostname
                '''
                script {
                    env.BASE_URL = sh(returnStdout: true, script: "aws cloudformation describe-stacks --stack-name staging-todo-list-aws --query 'Stacks[0].Outputs[?OutputKey==`BaseUrlApi`].OutputValue' --region us-east-1 --output text").trim()
                    writeFile file: 'rest_api.txt', text: env.BASE_URL
                }
                stash name: 'base_url', includes: 'rest_api.txt'
            }
        }

        stage('Rest Test') {
            agent { label 'agent-02' }
            steps {
                unstash name: 'code'
                unstash name: 'base_url'
                script { env.BASE_URL = readFile('rest_api.txt').trim() }
                catchError(buildResult: 'FAILURE', stageResult: 'FAILURE') {
                    sh '''
                        python3 -m venv .venv
                        . .venv/bin/activate
                        pytest --junitxml=result-rest.xml test/integration/todoApiTest.py
                        echo "---- WHO AM I? ----"
                        whoami
                        echo "---- HOSTNAME ----"
                        hostname
                    '''
                    junit testResults: '**/result-rest.xml'
                }
            }
        }

        stage('Promote') {
            agent { label 'built-in' }
            steps {
                unstash name: 'code'
                withCredentials([string(credentialsId: 'c88df4f8-f1d2-4b25-bbe2-da9d8ac9a94e', variable: 'GITHUB')]) {
                    sh """
                    echo "---- UPDATE REMOTE URL ----"
                    git config user.email "jenkins@yourdomain.com"
                    git config user.name "Jenkins CI"
                    git remote set-url origin https://jenkins:${GITHUB}@github.com/jguimeram/todo-list-aws.git

                    echo "---- UPDATE CHANGELOG ----"
                    git checkout develop
                    git pull origin develop
                    echo "Build #${env.BUILD_NUMBER}-R4CONFIG" >> CHANGELOG.md
                    git add -A
                    git commit -m "Update changelog - Build #${env.BUILD_NUMBER}-R4CONFIG"

                    echo "---- MERGE TO MASTER ----"
                    git checkout master
                    git pull origin master
                    git merge develop --no-edit
                    git tag -a "Release-${env.BUILD_NUMBER}-R4CONFIG" -m "Release version ${env.BUILD_NUMBER}-R4CONFIG"

                    echo "--- PUSH ----"
                    git push origin develop master --tags

                    echo "---- WHO AM I? ----"
                    whoami
                    echo "---- HOSTNAME ----"
                    hostname
                    """
                }
            }
        }
    }

    post {
        success {
            cleanWs()
            build job: 'todo-list-aws-cd-pipeline-config'
        }
    }
}
