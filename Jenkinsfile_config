pipeline {
    agent any
    options { skipDefaultCheckout() }
    stages {
        stage('Get Code') {
            agent { label 'built-in' }
            steps {
                echo '---- CLEAN BEFORE BUILD STARTS ----'
                cleanWs()
                echo '---- DOWNLOAD REPO ----'
                checkout scmGit(
                    branches: [[name: '*/develop']],
                    userRemoteConfigs: [[url: 'https://github.com/jguimeram/todo-list-aws']])
                echo '---- DOWNLOAD SAMCONFIG ----'
                sh '''
                curl -L https://raw.githubusercontent.com/jguimeram/todo-list-aws-config/refs/heads/staging/samconfig.toml -o samconfig.toml
                '''
                echo '---- WORKSPACE ----'
                echo WORKSPACE
                echo '---- WHO AM I? ----'
                sh '''
                whoami
                hostname
                '''
                script {
                    def msg = sh(script: 'git log -1 --pretty=%B', returnStdout: true).trim()
                    if (msg.contains('[ci skip]')) {
                        currentBuild.result = 'NOT_BUILT'
                        return
                    }
                }
                stash name: 'code', includes: '**'
            }
        }

        stage('Set Environment') {
            agent { label 'python' }
            steps {
                unstash name: 'code'
                sh '''
                python3 -m venv .venv
                . .venv/bin/activate
                PYTHONPATH=$PWD
                pip install requests pytest flake8 bandit
                whoami
                hostname
                '''
            }
        }

        stage('Static Tests') {
            parallel {
                stage('Flake8') {
                    agent { label 'agent-01' }
                    steps {
                        unstash name: 'code'
                        catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                            echo '---- STATIC ----'
                            sh '''
                            python3 -m venv .venv
                            . .venv/bin/activate
                            flake8 --exit-zero --format=pylint src > flake8.out
                            whoami
                            hostname
                            '''
                            recordIssues qualityGates: [[integerThreshold: 8, threshold: 8.0, type: 'TOTAL'], [criticality: 'FAILURE', integerThreshold: 10, threshold: 10.0, type: 'TOTAL']], sourceCodeRetention: 'NEVER', tools: [flake8(pattern: 'flake8.out')]
                        }
                    }
                }

                stage('Security') {
                    agent { label 'agent-01' }
                    steps {
                        unstash name: 'code'
                        catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                            sh '''
                            python3 -m venv .venv
                            . .venv/bin/activate
                            bandit --exit-zero -r src -f custom -o bandit.out --msg-template "{abspath}:{line}: [{test_id}] {msg}"
                            whoami
                            hostname
                            '''
                            recordIssues qualityGates: [[integerThreshold: 2, threshold: 2.0, type: 'TOTAL'], [criticality: 'FAILURE', integerThreshold: 4, threshold: 4.0, type: 'TOTAL']], sourceCodeRetention: 'NEVER', tools: [pyLint(pattern: 'bandit.out')]
                        }
                    }
                }
            }
        }

        stage('Deploy') {
            agent { label 'built-in' }
            steps {
                unstash name: 'code'
                sh '''
                sam build
                sam deploy --config-env staging
                whoami
                hostname
                '''
                script {
                    env.BASE_URL = sh(returnStdout: true, script: "aws cloudformation describe-stacks --stack-name staging-todo-list-aws --query 'Stacks[0].Outputs[?OutputKey==`BaseUrlApi`].OutputValue' --region us-east-1 --output text").trim()
                    writeFile file: 'rest_api.txt', text: env.BASE_URL
                }
                stash name: 'base_url', includes: 'rest_api.txt'
            }
        }

        stage('Rest Test') {
            agent { label 'agent-02' }
            steps {
                unstash name: 'code'
                unstash name: 'base_url'
                script {
                    env.BASE_URL = readFile('rest_api.txt').trim()
                }
                sh '''
                python3 -m venv .venv
                . .venv/bin/activate
                echo "Targeting URL: $BASE_URL"
                pytest test/integration/todoApiTest.py
                whoami
                hostname
                rm -fv rest_api.txt
                '''
            }
        }

        stage('Promote') {
            agent { label 'built-in' }
            steps {
                unstash name: 'code'
                    withCredentials([string(credentialsId: 'c88df4f8-f1d2-4b25-bbe2-da9d8ac9a94e', variable: 'GITHUB')]) {
                        sh """
                        echo "1. Update remote URL"
                        git config user.email "jenkins@yourdomain.com"
                        git config user.name "Jenkins CI"
                        git remote set-url origin https://jenkins:${GITHUB}@github.com/jguimeram/todo-list-aws.git

                        echo "2 - Update changelog"
                        git checkout develop
                        git pull origin develop
                        date >> CHANGELOG.md
                        git add -A
                        git commit -m "Update changelog - Build #${BUILD_NUMBER} [ci skip]"

                        echo "3 - Merge to master"
                        git checkout master
                        git pull origin master
                        git merge develop --no-edit

                        echo "4 - Push everything"
                        git push origin develop master

                        echo "Who am I?"
                        whoami
                        hostname
                        """
                    }
            }
        }
    }

    post {
        success {
            build job: 'todo-list-aws-cd-pipeline-config'
        }
    }
}
